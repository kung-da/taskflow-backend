{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npx prisma generate --schema prisma-postgres/schema.prisma"
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy --schema prisma-postgres/schema.prisma && npm start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
